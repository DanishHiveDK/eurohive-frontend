# ══════════════════════════════════════════════════════════════
# Eurohive Environment Configuration
# Copy this to .env.local and fill in your values
# ══════════════════════════════════════════════════════════════

# ── Database (Scaleway Managed PostgreSQL) ───────────────────
DATABASE_URL="postgresql://eurohive:password@localhost:5432/eurohive?schema=public"

# ── Redis (Scaleway Managed Redis) ───────────────────────────
REDIS_URL="redis://localhost:6379"

# ── NextAuth.js ──────────────────────────────────────────────
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"

# Google OAuth
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# LinkedIn OAuth
LINKEDIN_CLIENT_ID=""
LINKEDIN_CLIENT_SECRET=""

# ── Mollie Payments ──────────────────────────────────────────
# SECURITY: Never commit live API keys. Use test_ keys for development.
# Get your keys at: https://my.mollie.com/dashboard/developers/api-keys
# Test key for sandbox:  test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Live key for production: live_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
MOLLIE_API_KEY="test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
MOLLIE_PARTNER_ID=""
MOLLIE_PROFILE_ID=""
MOLLIE_WEBHOOK_URL="https://eurohive.eu/api/v1/payments/webhook"

# ── Scaleway Object Storage (S3-compatible) ──────────────────
S3_ENDPOINT="https://s3.fr-par.scw.cloud"
S3_REGION="fr-par"
S3_BUCKET="eurohive-uploads"
S3_ACCESS_KEY=""
S3_SECRET_KEY=""

# ── Meilisearch ──────────────────────────────────────────────
MEILISEARCH_HOST="http://localhost:7700"
MEILISEARCH_API_KEY=""

# ── Email (Postmark) ────────────────────────────────────────
POSTMARK_API_TOKEN=""
EMAIL_FROM="noreply@eurohive.eu"

# ── Mailchimp (Waitlist) ────────────────────────────────────
# SECURITY: Never commit API keys. Rotate after any exposure.
# Get your key at: https://us6.admin.mailchimp.com/account/api/
# Format: xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx-usX (where X = data centre)
MAILCHIMP_API_KEY="xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx-us6"
MAILCHIMP_LIST_ID=""
# The data centre is auto-extracted from the API key suffix (e.g. "us6")

# ── Sentry (EU region) ──────────────────────────────────────
SENTRY_DSN=""
SENTRY_ORG=""
SENTRY_PROJECT=""

# ── App Configuration ────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="Eurohive"
PLATFORM_FEE_PERCENT="10"

# ── Analytics (Google) ───────────────────────────────────────
# Analytics loads only in production by default.
# Set to "true" to enable in development:
NEXT_PUBLIC_ENABLE_ANALYTICS="false"
